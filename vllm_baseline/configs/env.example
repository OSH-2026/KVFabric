# Copy this file to:
# vllm_baseline/.env.local
#
# The scripts will source .env.local automatically when it exists.

# All path values below are interpreted relative to the KVFabric repository root
# unless you provide an absolute path.

# Reuse the repository-level virtual environment by default.
# VLLM_VENV_DIR=.venv

# Reuse the repository-level caches by default.
# VLLM_MODELS_DIR=.cache/models
# VLLM_CACHE_ROOT=.cache/vllm
# HF_HOME=.cache/huggingface
# XDG_CACHE_HOME=.cache

# Runtime logs and PID files.
# VLLM_RUNTIME_DIR=vllm_baseline/runtime

# Local server settings.
VLLM_HOST=127.0.0.1
VLLM_PORT=8000

# Proxy settings for WSL users who route traffic through the Windows host.
# Set this to 1 if you want scripts to auto-build:
#   http://<wsl-default-gateway>:<VLLM_PROXY_PORT>
VLLM_PROXY_ENABLE=0
VLLM_PROXY_PORT=7897

# Optional alternative install index for CUDA PyTorch.
VLLM_PIP_INDEX=https://download.pytorch.org/whl/cu129
