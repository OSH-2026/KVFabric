# Prefix caching variant for A/B comparison.
SUITE_VARIANT_NAME=prefix_caching_on
VARIANT_PRESET=qwen3_5_2b
VARIANT_DESCRIPTION="Official vLLM with prefix caching enabled. Compare with vanilla_vllm to measure prefix cache overhead and hit rate."

OVERRIDE_GPU_MEMORY_UTILIZATION=0.85
OVERRIDE_MAX_MODEL_LEN=2048
OVERRIDE_MAX_NUM_SEQS=16
OVERRIDE_LANGUAGE_MODEL_ONLY=1
ENABLE_PREFIX_CACHING=1
