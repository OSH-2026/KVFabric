# Baseline variant: official vLLM without any KV cache modifications.
SUITE_VARIANT_NAME=vanilla_vllm
VARIANT_PRESET=qwen3_5_2b
VARIANT_DESCRIPTION="Official vLLM baseline, no KV compression, no prefix caching."

# Override defaults from the preset profile
OVERRIDE_GPU_MEMORY_UTILIZATION=0.85
OVERRIDE_MAX_MODEL_LEN=2048
OVERRIDE_MAX_NUM_SEQS=16
OVERRIDE_LANGUAGE_MODEL_ONLY=1
ENABLE_PREFIX_CACHING=0
